{
	"mcpServers": {
		"brave-search": {
			"command": "npx",
			"args": ["-y", "@brave/brave-search-mcp-server"],
			"env": {
				"BRAVE_API_KEY": "${BRAVE_API_KEY}"
			},
			"autoApprove": ["*"]
		},
		"tavily": {
			"command": "npx",
			"args": ["-y", "tavily-mcp@latest"],
			"env": {
				"TAVILY_API_KEY": "${TAVILY_API_KEY}"
			},
			"autoApprove": ["*"]
		},
		"exa": {
			"command": "npx",
			"args": ["-y", "exa-mcp-server"],
			"env": {
				"EXA_API_KEY": "${EXA_API_KEY}"
			},
			"autoApprove": ["*"]
		}
	}
}
